# Copy this file to .env and fill in what you need. .env is gitignored -
# never commit real keys.

# --- Local backend (default: LM Studio at localhost:1234) ---
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL_NAME=qwen2.5-14b-instruct-1m

# --- Cloud backend (the frontend's "Cloud" toggle) ---
# Any OpenAI-compatible endpoint works. Two examples:

# OpenAI (default base URL if CLOUD_LLM_BASE_URL is unset):
# CLOUD_LLM_API_KEY=sk-...
# CLOUD_LLM_MODEL_NAME=gpt-4o-mini

# Gemini, via Google's OpenAI-compatibility layer:
# CLOUD_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CLOUD_LLM_API_KEY=your-gemini-api-key
# CLOUD_LLM_MODEL_NAME=gemini-3.5-flash
# (model names move fast - check https://ai.google.dev/gemini-api/docs/openai
# for whatever is current if this one 404s)
