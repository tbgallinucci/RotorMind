new file mode 100644
index 0000000..deee0fb
--- /dev/null
+++ b/assistant/tests/test_grounding.py
@@ -0,0 +1,147 @@
+"""Grounding guard + self-correction gate — fully mocked, no network, no LLM.
+
+Covers the exact failure that motivated it: the model retrieves the right page,
+then asserts a figure that is NOT on it ("API 684 requires 30%") wrapped in a
+real-looking (wiki: ...) citation. The guard must catch it; run_agent must
+self-correct once and, if the model still can't ground it, fail closed.
+
+Also covers that the answer genuinely streams (multiple `delta` events) rather
+than arriving as one block, and that a `replace` event is what the frontend
+uses to swap in the corrected text.
+"""
+
+import asyncio
+import json
+
+from assistant.app import agent, grounding
+from assistant.tests.streaming_fakes import _NonStreamResponse, content_stream
+
+
+# ---------------------------------------------------------------- unit tests
+
+def test_flags_number_not_on_cited_page():
+    pages = {"gloss": "Separation margin: required distance; grows with AF "
+                      "(see API 684 concepts)."}
+    answer = "API 684 requires at least 30% margin (wiki: gloss, Terms)."
+    problems = grounding.find_violations(answer, pages)
+    # 684 is on the page, 30 is not -> exactly the fabricated figure is flagged.
+    assert any("30" in p and "gloss" in p for p in problems)
+    assert not any("684" in p for p in problems)
+
+
+def test_passes_number_present_on_cited_page():
+    pages = {"cs": "Indicative margins are 15-16 percent below and 20-26 above."}
+    answer = "Indicative margins run about 15 to 16 percent (wiki: cs, Margins)."
+    assert grounding.find_violations(answer, pages) == []
+
+
+def test_skips_when_page_text_unavailable():
+    answer = "API 684 requires 30% (wiki: gloss, Terms)."
+    assert grounding.find_violations(answer, {}, loader=None) == []
+
+
+def test_ignores_numbers_inside_citation_tokens():
+    pages = {"cs": "no numbers here at all"}
+    answer = "See the concept (wiki: cs, Section 2.5) and (run: 2026-07-19-run-003)."
+    assert grounding.find_violations(answer, pages) == []
+
+
+# --------------------------------------------------- integration (run_agent)
+
+CONTEXT = (
+    "=== WIKI LIBRARY CONTEXT ===\n\n"
+    "### WIKI PAGE: gloss\n## Terms\n"
+    "Separation margin: required distance between a critical and the operating "
+    "range; grows with AF (see API 684 concepts).\n\n"
+    "### WIKI PAGE: cs\n## Separation margin\n"
+    "Indicative API 684 figures: 15-16 percent below the minimum, 20-26 percent "
+    "above the maximum, increasing with AF.\n"
+)
+
+BAD = "API 684 requires a separation margin of at least 30% (wiki: gloss, Terms)."
+GOOD = ("The exact API 684 margin is not stated in the notes; the indicative "
+        "figures are 15-16 percent below and 20-26 percent above "
+        "(wiki: cs, Separation margin).")
+
+
+class SelfCorrectingLLM:
+    """Streams the fabrication first (final-answer round). The one-shot
+    self-correction call is non-streaming (agent._vet_and_finalize), so it
+    returns a plain response object instead."""
+    def __init__(self):
+        self.calls = []
+        self.chat = self
+        self.completions = self
+
+    async def create(self, **kwargs):
+        self.calls.append(kwargs)
+        if kwargs.get("stream"):
+            return content_stream(BAD)
+        # non-streaming call -> this is the correction round
+        return _NonStreamResponse(GOOD)
+
+
+class StubbornLLM(SelfCorrectingLLM):
+    """Never grounds it, even after correction -> should fail closed."""
+    async def create(self, **kwargs):
+        self.calls.append(kwargs)
+        if kwargs.get("stream"):
+            return content_stream(BAD)
+        return _NonStreamResponse(BAD)
+
+
+def _run(llm):
+    messages = [
+        {"role": "system", "content": agent.wiki_logic.SYSTEM_PROMPT},
+        {"role": "system", "content": CONTEXT},
+        {"role": "user", "content": "Is run-003 compliant with API 684 at 60 Hz?"},
+    ]
+    async def go():
+        return [chunk async for chunk in agent.run_agent(llm, messages)]
+    return asyncio.run(go())
+
+
+def _reconstruct(raw_lines):
+    displayed = ""
+    for line in raw_lines:
+        for sub in line.splitlines():
+            if not sub.strip():
+                continue
+            evt = json.loads(sub)
+            if evt["type"] == "delta":
+                displayed += evt["text"]
+            elif evt["type"] == "replace":
+                displayed = evt["text"]
+    return displayed
+
+
+def test_answer_streams_before_the_gate_checks_it():
+    llm = SelfCorrectingLLM()
+    raw = _run(llm)
+    delta_events = [json.loads(s) for line in raw for s in line.splitlines()
+                    if s.strip() and json.loads(s)["type"] == "delta"]
+    assert len(delta_events) > 1, "the (eventually-rejected) answer should still stream token by token"
+    # the fabrication really was shown to the user, if only briefly
+    streamed_text = "".join(e["text"] for e in delta_events)
+    assert "30%" in streamed_text
+
+
+def test_self_corrects_a_cited_fabrication_via_replace_event():
+    llm = SelfCorrectingLLM()
+    raw = _run(llm)
+    final = _reconstruct(raw)
+    assert "30%" not in final, "the fabricated threshold must not survive as the final text"
+    assert "15-16" in final and "(wiki: cs" in final
+
+    types_seen = [json.loads(s)["type"] for line in raw for s in line.splitlines() if s.strip()]
+    assert "replace" in types_seen, "correction must arrive as a replace event for the frontend"
+    assert llm.calls[0].get("stream") is True       # the streamed (bad) answer
+    assert llm.calls[1].get("stream") is not True   # the non-streaming correction
+
+
+def test_fails_closed_when_still_ungrounded():
+    llm = StubbornLLM()
+    raw = _run(llm)
+    final = _reconstruct(raw)
+    assert final == agent.FAIL_CLOSED
+    assert "30%" not in final
